# Discord Bot credentials
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_discord_application_client_id_here

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/velora?retryWrites=true&w=majority

# Optional session secret (used internally)
SESSION_SECRET=some_random_long_secret_string

# Port — Render sets this automatically. Do NOT set manually in production.
# PORT=3000
